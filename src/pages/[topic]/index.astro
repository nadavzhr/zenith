---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import ArticlePreview from '../../components/ArticlePreview.astro';
import bgImage from '../../assets/watercolor-background.png';
import PageBackground from '../../components/PageBackground.astro';
import {
  getTopics,
  getArticlesByTopic,
  assertArticlesHaveTopics,
  articleSlug,
  formatDate,
  articleDate,
} from '../../lib/content';
import { RESERVED_SLUGS } from '../../site.config';

export async function getStaticPaths() {
  await assertArticlesHaveTopics();
  const topics = await getTopics();
  for (const topic of topics) {
    if (RESERVED_SLUGS.includes(topic.id)) {
      throw new Error(
        `Topic slug "${topic.id}" collides with a reserved top-level route. ` +
          `Rename the file in src/content/topics/.`,
      );
    }
  }
  return topics.map((topic) => ({ params: { topic: topic.id }, props: { topic } }));
}

const base = import.meta.env.BASE_URL;
const { topic } = Astro.props;
const { Content } = await render(topic);
const articles = await getArticlesByTopic(topic.id);
---

<BaseLayout title={topic.data.title} description={topic.data.description}>
  <PageBackground src={bgImage} />

  {topic.data.cover && (
    <div class="w-full h-[300px] md:h-[400px] overflow-hidden mb-12 bg-surface-container rounded-sm border border-on-surface/5">
      <Image 
        src={topic.data.cover} 
        alt={topic.data.title} 
        width={1600}
        height={600}
        class="w-full h-full object-cover filter grayscale contrast-125 opacity-40" 
      />
    </div>
  )}

  <header class="mb-16 md:mb-24">
    <div class="text-[14px] font-medium uppercase tracking-widest text-primary mb-4">Topic</div>
    <h1 class="font-serif text-[48px] md:text-[64px] font-bold tracking-[-0.02em] text-on-surface mb-6 leading-[1.1]">
      {topic.data.title}
    </h1>
    <p class="text-[18px] md:text-[20px] text-on-surface-variant max-w-2xl leading-[1.6]">
      {topic.data.description}
    </p>
  </header>

  <div class="prose mb-16">
    <Content />
  </div>

  <div class="editorial-divider mb-12"></div>

  <section class="mb-section-gap">
    <h2 class="font-serif text-[32px] font-semibold text-on-surface mb-8">Articles</h2>
    <div class="flex flex-col">
      {articles.length === 0 ? (
        <p class="text-secondary">No articles in this topic yet.</p>
      ) : (
        articles.map((article, idx) => (
          <ArticlePreview 
            article={article} 
            layout="row" 
            class={idx === 0 ? 'border-t-0' : ''} 
          />
        ))
      )}
    </div>
  </section>
</BaseLayout>
