---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { ArrowRight } from 'lucide-react';
import ArticlePreview from '../components/ArticlePreview.astro';
import PageBackground from '../components/PageBackground.astro';
import {
  getTopics,
  getArticles,
  topicOf,
  articleSlug,
  articleDateOrEpoch,
} from '../lib/content';

import monkImage from '../assets/meditating-monk.jpeg';

const base = import.meta.env.BASE_URL;
const articles = await getArticles();
const topics = await getTopics();

// Find featured article or use the latest one.
const sortedArticles = [...articles].sort((a, b) => articleDateOrEpoch(b).getTime() - articleDateOrEpoch(a).getTime());
const featuredArticle = sortedArticles.find((a) => a.data.featured) || sortedArticles[0];
const featuredPath = featuredArticle ? `${base}${topicOf(featuredArticle)}/${articleSlug(featuredArticle)}` : '#';
const featuredBg = featuredArticle?.data.cover;

// Recent articles (excluding featured if possible, but let's just take top 3).
const recentArticles = sortedArticles.slice(0, 3);

const categories = topics.slice(0, 3);
---

<BaseLayout>
  <PageBackground src={monkImage} />

  <section class="mb-section-gap mt-16 md:mt-32 flex flex-col items-center text-center">
    <div class="max-w-3xl">
      <h1 class="font-serif text-[56px] md:text-[84px] font-bold text-on-surface mb-6 leading-[1.1] tracking-[-0.03em]">
        Structural Thought.
      </h1>
      <p class="text-[18px] md:text-[22px] text-on-surface/80 max-w-xl mx-auto mb-12 leading-[1.6]">
        A digital vault for technical mastery. Breaking down complex systems through first-principles thinking.
      </p>
    </div>
  </section>

  {/* Featured Series / Article */}
  <section class="mb-section-gap relative overflow-hidden bg-surface border border-on-surface/5 rounded-sm group flex items-center justify-center text-center py-16 px-6 md:py-24 md:px-12">
    {featuredBg && (
      <Image 
        src={featuredBg} 
        alt="Abstract architectural background" 
        width={1600}
        height={900}
        class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125 opacity-20 dark:opacity-30 group-hover:opacity-30 dark:group-hover:opacity-40 transition-opacity duration-700" 
      />
    )}
    <div class="relative z-10 flex flex-col items-center max-w-3xl mx-auto">
      <div class="text-[14px] font-medium text-primary uppercase tracking-widest mb-4">Featured</div>
      <h2 class="font-serif text-[32px] md:text-[40px] font-semibold text-on-surface mb-6 leading-[1.2] tracking-tight">
        {featuredArticle ? featuredArticle.data.title : 'The Silicon Canvas'}
      </h2>
      <p class="text-[16px] md:text-[18px] text-on-surface mb-8 leading-[1.6] max-w-2xl px-4">
        {featuredArticle ? featuredArticle.data.description : 'A deep dive into the aesthetic decisions behind technical systems.'}
      </p>
      <a href={featuredPath} class="inline-flex items-center gap-2 border-b-2 border-primary-container pb-1 text-[16px] font-medium text-on-surface hover:text-primary transition-all hover:gap-3 group/link">
        Read the Featured Piece
        <ArrowRight size={16} className="transition-transform group-hover/link:translate-x-1" />
      </a>
    </div>
  </section>

  {/* Recent Writing */}
  <section class="mb-section-gap">
    <h2 class="font-serif text-[28px] md:text-[32px] font-bold text-on-surface mb-8">Recent Writing</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {recentArticles.map((article) => (
        <ArticlePreview article={article} layout="card" />
      ))}
    </div>
    <div class="mt-12 flex">
      <a href={`${base}articles`} class="inline-flex w-fit items-center gap-2 border-b-2 border-primary-container pb-1 text-[16px] text-on-surface font-medium hover:text-primary transition-all hover:gap-3 group">
        View All Writing
        <ArrowRight size={16} className="transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </section>

  {/* Browse by Category */}
  <section class="mt-section-gap pt-16 border-t border-on-surface/10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <h2 class="font-serif text-[32px] md:text-[40px] font-bold text-on-surface mb-4">Explore the Vault</h2>
        <p class="text-secondary max-w-xl text-[16px] md:text-[18px]">
          Organized by fundamental domains, these collections serve as the primary entry points into the digital record.
        </p>
      </div>
      <a href={`${base}topics`} class="inline-flex self-start w-fit items-center gap-2 border-b-2 border-primary-container pb-1 text-[16px] text-on-surface font-medium hover:text-primary transition-all hover:gap-3 group">
        All Topics
        <ArrowRight size={16} className="transition-transform group-hover:translate-x-1" />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {topics.map((topic) => (
        <a 
          href={`${base}${topic.id}`} 
          class="group relative aspect-[4/5] overflow-hidden bg-surface-container rounded-sm border border-on-surface/5"
        >
          {topic.data.cover && (
            <Image 
              src={topic.data.cover} 
              alt={topic.data.title} 
              width={600}
              height={750}
              class="absolute inset-0 w-full h-full object-cover filter grayscale contrast-125 opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]" 
            />
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/20 to-transparent opacity-80 group-hover:opacity-60 transition-opacity duration-700"></div>
          <div class="absolute inset-0 p-8 flex flex-col justify-end">
            <h3 class="font-serif text-[24px] font-bold text-on-surface group-hover:text-primary transition-colors leading-tight mb-2">
              {topic.data.title}
            </h3>
            <p class="text-[13px] text-secondary line-clamp-2 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-75">
              {topic.data.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
