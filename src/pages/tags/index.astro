---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBackground from '../../components/PageBackground.astro';
import bgImage from '../../assets/watercolor-background.png';
import { getArticles, tagsOf, tagSlug } from '../../lib/content';

const base = import.meta.env.BASE_URL;
const articles = await getArticles();
const tags = tagsOf(articles);

const count = (tag: string) => articles.filter((a) => a.data.tags.includes(tag)).length;
---

<BaseLayout title="Tags" description="Browse articles by tag.">
  <PageBackground src={bgImage} />
  <header class="mb-12">
    <div class="text-[14px] font-medium uppercase tracking-widest text-primary mb-4">Index</div>
    <h1 class="font-serif text-[48px] md:text-[64px] font-bold tracking-[-0.02em] text-on-surface mb-6 leading-[1.1]">
      Tags.
    </h1>
    <p class="text-[18px] md:text-[20px] text-on-surface-variant max-w-2xl leading-[1.6]">
      Cross-topic index of every tag used across Zenith. A different way to navigate the architecture.
    </p>
  </header>

  {
    tags.length === 0 ? (
      <p class="mt-8 text-secondary">No tags yet.</p>
    ) : (
      <ul class="mt-8 flex flex-wrap gap-4">
        {tags.map((tag) => (
          <li>
            <a
              href={`${base}tags/${tagSlug(tag)}`}
              class="px-4 py-2 rounded-full bg-primary/5 text-primary text-[12px] uppercase tracking-widest font-medium border border-primary/20 hover:bg-primary/10 transition-all flex items-center gap-3"
            >
              #{tag}
              <span class="text-[11px] font-mono text-primary/40">({count(tag)})</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
